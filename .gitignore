# Python
__pycache__/
*.pyc
.venv/

# ---- データ生成物（git 追跡外） ----
# T3 raw テキスト: PDF から再生成可能。data/latest/raw/ と data/archive/<ver>/raw/ 両方にマッチ
data/**/raw/

# 各版の Markdown レンダリング結果（巨大かつ自動生成）。r6, r8, r10... 任意の版に対応
docs/r*/
# ※ docs/diff/ は人間が一次窓口として参照するため追跡対象（上のパターンに含まれない）

# MkDocs のビルド成果物
site/

# ---- 注意: 以下は追跡対象。.gitignore で誤って隠さないこと ----
# data/latest/      現行版データ
# data/archive/     旧版スナップショット
#                   （かつて "archive/" と書いて data/archive/ も全部無視してハマった）
# docs/diff/        改定差分 Markdown

# 一時ファイル
.tmp-cleanup/
